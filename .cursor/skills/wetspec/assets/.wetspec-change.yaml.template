# wetspec Change 级状态（scope: change）
# 位于 <changes_root>/<name>/.wetspec.yaml（默认 wetspec/changes/）
# 增量 Spec 只写入同目录 wetspec-delta/，archive 时回写主 specs/

version: "1.1"
scope: change
workflow: delta
phase: idle
mode: incremental

change_name: null
main_specs: specs/
delta_dir: wetspec-delta

prd:
  current: null
  previous: null

last_diff: null
affected_specs: []
archived: false
auto_transition: true
openspec_change: null
design_doc: null
