{
  "name": "@electrum/preload",
  "version": "0.1.0",
  "description": "ContextBridge helpers for Electrum renderer IPC (preload)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^32.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "electron",
    "electrum",
    "preload",
    "contextBridge",
    "ipc"
  ],
  "license": "MIT"
}
