{
  "name": "electron-mvc",
  "version": "0.1.0",
  "description": "NestJS-inspired MVC framework for Electron, powered by TS5 native decorators",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "electron": ">=20.0.0",
    "typescript": ">=5.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^32.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "electron",
    "framework",
    "mvc",
    "dependency-injection",
    "decorator",
    "ipc",
    "nestjs",
    "typescript5",
    "stage3-decorators"
  ],
  "license": "MIT"
}
